# Variables d'environnement pour Claude-NotebookLM Connector

# API Google NotebookLM
NOTEBOOKLM_API_KEY=your_google_api_key_here

# Configuration du serveur
PORT=5000
FLASK_ENV=development
FLASK_DEBUG=True

# Configuration Claude (pour future intégration directe)
CLAUDE_API_KEY=your_claude_api_key_here

# Configuration de la base de données (optionnel)
DATABASE_URL=sqlite:///notebooklm.db

# Configuration CORS
ALLOWED_ORIGINS=http://localhost:3000,https://claude.ai

# Logging
LOG_LEVEL=INFO
